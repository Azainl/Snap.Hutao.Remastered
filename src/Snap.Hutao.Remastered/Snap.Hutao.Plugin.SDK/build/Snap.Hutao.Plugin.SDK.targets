<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <HutaoPluginOutputPath>$(OutputPath)$(AssemblyName).hutao</HutaoPluginOutputPath>
    <HutaoPluginManifestPath>$(MSBuildProjectDirectory)\manifest.json</HutaoPluginManifestPath>
    <HutaoPluginIconPath>$(MSBuildProjectDirectory)\icon.png</HutaoPluginIconPath>
    <HutaoPluginInjectDirectory>$(MSBuildProjectDirectory)\inject</HutaoPluginInjectDirectory>
    <HutaoPluginLibDirectory>$(MSBuildProjectDirectory)\lib</HutaoPluginLibDirectory>
    <GenerateHutaoPlugin Condition="'$(GenerateHutaoPlugin)' == ''">true</GenerateHutaoPlugin>
    <HutaoPluginExcludePatterns Condition="'$(HutaoPluginExcludePatterns)' == ''">Snap.Hutao.Remastered*;Microsoft.WindowsAppSDK*;Microsoft.Windows.SDK*;WinRT.Runtime*;CommunityToolkit*;Microsoft.UI.Xaml*;Microsoft.Web.WebView2*</HutaoPluginExcludePatterns>
  </PropertyGroup>

  <Target Name="GenerateHutaoPlugin" AfterTargets="Build" Condition="'$(GenerateHutaoPlugin)' == 'true'">
    <Message Importance="high" Text="Generating .hutao plugin package: $(HutaoPluginOutputPath)" />
    
    <Error Condition="!Exists('$(HutaoPluginManifestPath)')" 
           Text="Plugin manifest.json not found at $(HutaoPluginManifestPath). Please create a manifest.json file for your plugin." />
    
    <ItemGroup>
      <HutaoPluginFiles Include="$(TargetPath)" />
      <HutaoPluginFiles Include="$(HutaoPluginManifestPath)" />
      <HutaoPluginFiles Include="$(HutaoPluginIconPath)" Condition="Exists('$(HutaoPluginIconPath)')" />
      <HutaoPluginFiles Include="$(HutaoPluginInjectDirectory)\**\*" Condition="Exists('$(HutaoPluginInjectDirectory)')" />
      <HutaoPluginFiles Include="$(HutaoPluginLibDirectory)\**\*" Condition="Exists('$(HutaoPluginLibDirectory)')" />
      
      <!-- Include all referenced DLLs except those matching exclude patterns -->
      <HutaoPluginFiles Include="@(ReferenceCopyLocalPaths->'%(FullPath)')" 
                       Condition="'%(ReferenceCopyLocalPaths.Extension)' == '.dll' 
                       and !$([System.Text.RegularExpressions.Regex]::IsMatch('%(Filename)', '$(HutaoPluginExcludePatterns.Replace(';', '|').Replace('*', '.*'))'))" />
    </ItemGroup>
    
    <Message Importance="high" Text="Creating .hutao package with @(HutaoPluginFiles->Count()) files" />
    
    <!-- Create the .hutao file using inline task -->
    <CreateHutaoPluginPackageTask
      OutputPath="$(HutaoPluginOutputPath)"
      Files="@(HutaoPluginFiles)"
      AssemblyName="$(AssemblyName)"
      ProjectDirectory="$(MSBuildProjectDirectory)" />
  </Target>

  <UsingTask TaskName="CreateHutaoPluginPackageTask" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <OutputPath ParameterType="System.String" Required="true" />
      <Files ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
      <AssemblyName ParameterType="System.String" Required="true" />
      <ProjectDirectory ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.IO.Compression" />
      <Code Type="Fragment" Language="cs">
<![CDATA[
try
{
    Log.LogMessage(MessageImportance.High, "Creating plugin package: " + OutputPath);
    
    // Create temporary directory
    string tempDir = Path.Combine(Path.GetTempPath(), "hutao_plugin_" + Guid.NewGuid().ToString("N"));
    Directory.CreateDirectory(tempDir);
    
    try
    {
        // Copy all files to temp directory, preserving directory structure
        foreach (ITaskItem file in Files)
        {
            string sourcePath = file.GetMetadata("FullPath");
            string fileName = Path.GetFileName(sourcePath);
            
            // Check if this is the main plugin DLL
            string targetPath;
            if (fileName.Equals(AssemblyName + ".dll", StringComparison.OrdinalIgnoreCase))
            {
                // Main plugin DLL goes to root
                targetPath = Path.Combine(tempDir, fileName);
            }
            else
            {
                // Get relative path from project directory for other files
                string relativePath = GetRelativePath(sourcePath, ProjectDirectory);
                targetPath = Path.Combine(tempDir, relativePath);
            }
            
            // Ensure directory exists
            Directory.CreateDirectory(Path.GetDirectoryName(targetPath));
            
            File.Copy(sourcePath, targetPath, true);
        }
        
        // Create ZIP archive
        if (File.Exists(OutputPath))
        {
            File.Delete(OutputPath);
        }
        
        ZipFile.CreateFromDirectory(tempDir, OutputPath, CompressionLevel.Optimal, false);
        
        Log.LogMessage(MessageImportance.High, "Plugin package created successfully: " + OutputPath);
    }
    finally
    {
        // Clean up temp directory
        try
        {
            Directory.Delete(tempDir, true);
        }
        catch
        {
            // Ignore cleanup errors
        }
    }
}
catch (Exception ex)
{
    Log.LogErrorFromException(ex);
    return false;
}

return true;

string GetRelativePath(string fullPath, string basePath)
{
    // Make sure basePath ends with directory separator
    if (!basePath.EndsWith(Path.DirectorySeparatorChar.ToString()))
        basePath += Path.DirectorySeparatorChar;
    
    Uri fullUri = new Uri(fullPath);
    Uri baseUri = new Uri(basePath);
    
    Uri relativeUri = baseUri.MakeRelativeUri(fullUri);
    return Uri.UnescapeDataString(relativeUri.ToString()).Replace('/', Path.DirectorySeparatorChar);
}
]]>
      </Code>
    </Task>
  </UsingTask>

</Project>
